# --- VocabNet Data ---
# We ignore the actual user database and book uploads
backend/data/*.db
backend/data/*.db-journal
backend/data/*.sqlite
backend/data/library/
backend/data/dict_cache/

# We DO track reference data files
!backend/data/collocations.json
!backend/data/idioms.json
!backend/data/phrasal_verbs.txt

